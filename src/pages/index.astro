---
import '../styles/global.css';
import CatWANTEDProfilerV3 from '../components/CatWANTEDProfilerV3';
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>父猫指名手配シミュレーター | 猫の毛色遺伝</title>
		<meta name="description" content="ママ猫と子猫の毛色・白斑から、遺伝法則に基づいてパパ猫（犯ニャン）を指名手配！猫の毛色遺伝・父猫特定シミュレーター。" />
	</head>
	<body class="h-screen overflow-hidden text-slate-900 font-sans selection:bg-pink-200 selection:text-pink-900 flex flex-col" style="background-color: #FFFBEB;">

		{/* Header */}
		<header class="w-full py-2 px-4 text-center border-b border-amber-100 shadow-sm relative z-10 shrink-0" style="background-color: #FFFBEB;">
			<h1 class="text-lg font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-500 via-orange-500 to-pink-500 tracking-tight leading-tight">
				🔍 父猫指名手配シミュレーター
			</h1>
			<p class="text-[10px] text-amber-400 font-bold tracking-wider leading-tight">WANTED! — 猫の毛色遺伝で犯人（パパ猫）をプロファイリング</p>
		</header>

		{/* Main — h-screen minus header/footer, max-w-screen-lg centered */}
		<main class="flex-1 min-h-0 w-full max-w-screen-lg mx-auto px-4 py-3 flex flex-col">
			<CatWANTEDProfilerV3 client:load />
		</main>

		{/* Footer */}
		<footer class="py-1.5 text-center text-slate-300 text-[9px] border-t border-amber-50 shrink-0 relative z-10" style="background-color: #FFFBEB;">
			<p>&copy; 2026 Cat Genetics Simulator. Astro + React + Tailwind CSS.</p>
		</footer>
	</body>
</html>
